# Ottieni la tua API key gratuita da: https://www.themoviedb.org/settings/api
TMDB_API_KEY=la_tua_api_key_qui

# --- Database (PostgreSQL) ---
# In locale: i valori della risorsa Postgres di Coolify (DB_HOST = IP del server,
# DB_PORT = la "Public Port" esposta da Coolify).
# In produzione: DB_HOST è il nome interno della risorsa Postgres sulla rete Docker.
DB_USER=watchnext
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=watchnext
